# Copy this file to .env and fill in the values.

# Path to the JSON file used for task persistence
TASKS_FILE=tasks.json

# LLM provider selection: azure | ollama | openai_compat
PROVIDER=azure

# Azure OpenAI
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT=
AZURE_API_VERSION=2024-02-01

# Ollama (local)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI-compatible (Qwen, Mistral-Small, …)
COMPAT_ENDPOINT=
COMPAT_API_KEY=
COMPAT_MODEL=
