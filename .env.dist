# Copy this file to .env and fill in the values.

# MySQL connection string
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/taskmanager

# Flask secret key (use a long random string in production)
SECRET_KEY=change-me

# LLM provider selection: azure | ollama | openai_compat
PROVIDER=azure

# Azure OpenAI
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT=
AZURE_API_VERSION=2024-02-01

# Ollama (local)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI-compatible (Qwen, Mistral-Small, …)
COMPAT_ENDPOINT=
COMPAT_API_KEY=
COMPAT_MODEL=
